# -------------------------------------------------------
# Copy this file to .env on the SERVER only — never commit .env
# -------------------------------------------------------

# SMTP settings (use cPanel mail or external provider like Gmail/SendGrid)
SMTP_HOST=mail.yourdomain.com
SMTP_PORT=587
SMTP_SECURE=false        # true only for port 465 (SSL); false for 587 (STARTTLS)
SMTP_USER=noreply@yourdomain.com
SMTP_PASS=your-email-password

# Where form submissions are delivered
TO_EMAIL=you@yourdomain.com
