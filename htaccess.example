# -------------------------------------------------------
# SERVER-SIDE .htaccess — do not commit this file.
# Manage it directly in cPanel File Manager.
#
# IMPORTANT: cPanel's "Setup Node.js App" auto-appends the
# Passenger block at the bottom when you save the app config.
# Never deploy .htaccess via CI/CD — it will wipe those directives.
# -------------------------------------------------------

# Optional: prevent search engine indexing (staging sites)
Header set X-Robots-Tag "noindex, nofollow"

# Optional: basic auth password protection (staging sites)
AuthType Basic
AuthName "Staging"
AuthUserFile /home/YOUR_CPANEL_USER/.htpasswd
Require valid-user

# -------------------------------------------------------
# Passenger directives — auto-generated by cPanel.
# These will be appended by cPanel when you save the Node.js app.
# Shown here for reference only.
# -------------------------------------------------------
# PassengerAppRoot /home/YOUR_CPANEL_USER/YOUR_APP_DIR
# PassengerBaseURI /
# PassengerNodejs /home/YOUR_CPANEL_USER/nodevenv/YOUR_APP_DIR/20/bin/node
# PassengerAppType node
# PassengerStartupFile app.js
