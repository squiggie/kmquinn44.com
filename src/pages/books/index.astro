---
import Layout from '../../layouts/Layout.astro';
import Container from '../../components/site/Container.astro';
import ReviewCard from '../../components/site/ReviewCard.astro';
import { getProducts } from '../../lib/content';
import { getCollection } from 'astro:content';

const products = await getProducts();
const allReviews = await getCollection('reviews');

// Get featured reviews by book
const getReviewsByBook = (bookTitle) => {
  return allReviews
    .filter(r => r.data.book === bookTitle && r.data.featured)
    .slice(0, 2); // Show max 2 reviews per book
};

// Create book detail structure with synopses
const bookDetails = [
  {
    slug: 'torn-robes-kings-highway',
    title: 'Torn Robes: The King\'s Highway',
    image: '/images/books/kings-highway.png',
    number: 'Book Three',
    availability: 'coming-soon',
    synopsis: [
      'The trilogy reaches its sacred conclusion. After the choices that divided Gilford and the reckoning that shattered certainties, K.M. Quinn brings her characters to the King\'s Highway—a spiritual and emotional crossroads where every soul must finally ask: What am I willing to become?',
      'In this profound final volume, Pastor John, Louise Taylor, Titus, Sharise, and all of Gilford face their ultimate transformations. Where does faith lead when tested to its breaking point? How does grace flow through the deepest wounds? And what happens when we finally surrender to the path God has been calling us toward all along?',
      'The King\'s Highway is not an ending—it\'s a homecoming. A stunning conclusion to K.M. Quinn\'s masterwork of faith, redemption, and the unshakeable belief that all things are possible with God.'
    ],
    cta: 'Be the first to know when preorders open'
  },
  {
    slug: 'torn-robes-reckoning',
    title: 'Torn Robes: Reckoning',
    image: '/images/books/reckoning.jpg',
    number: 'Book Two',
    availability: 'in-stock',
    synopsis: [
      'The consequences of choice demand accountability. As Gilford moves forward from the spiritual awakening Pastor John brought, the town must reckon with the cost of transformation. Hidden truths surface. Long-buried secrets threaten relationships. And the characters readers met in Choices discover that real faith isn\'t measured in moments of inspiration—it\'s tested in the crucible of everyday life.',
      'Reckoning is K.M. Quinn\'s most intimate and challenging work. Through Titus\'s intellectual crisis, Louise\'s fierce protection of those she loves, Sharise\'s coming-of-age awakening, and Pastor John\'s deepening ministry, we witness how accountability becomes grace, and how true growth requires facing what we\'ve been running from.',
      'This is the book that transforms a series into a spiritual journey. By the final page, characters and readers alike understand: reckoning isn\'t punishment. It\'s the price of wisdom, and the foundation of real transformation.'
    ],
    cta: 'Dive deeper into the story'
  },
  {
    slug: 'torn-robes-choices',
    title: 'Torn Robes: Choices',
    image: '/images/books/torn-robes-choices.png',
    number: 'Book One',
    availability: 'in-stock',
    synopsis: [
      'What happens when a man of faith arrives in a town that isn\'t looking for salvation? K.M. Quinn\'s debut novel introduces us to Gilford—a small New England town with big secrets—and Pastor John, a man answering a divine calling he never expected. What unfolds is a story that will challenge everything you think you know about faith, community, and the power of one person\'s willingness to follow God\'s call, no matter the cost.',
      'Through the eyes of Pastor John, Louise Taylor, Titus, Sharise, and others, we enter a world where teenagers question everything, adults defend their status quo, and the strongest voices are often the quietest ones. Torn Robes: Choices asks the central question of faith: What do you do when God calls you to something that doesn\'t make sense? When your choices are torn between comfort and conviction, between who you were and who you\'re meant to become?',
      'This is literary fiction with soul. A modern exploration of spiritual awakening, community, and the transformative power of one pastor\'s faith in a town desperate for hope—whether it knows it or not.'
    ],
    cta: 'Begin the journey'
  }
];

// Get products and group by book
const getEditionsByBook = (bookTitle) => {
  return products.filter(p => p.data.book === bookTitle).sort((a, b) => {
    const formatOrder = ['Hardcover', 'Paperback', 'Signed Hardcover', 'Signed Paperback'];
    return (formatOrder.indexOf(a.data.format) - formatOrder.indexOf(b.data.format));
  });
};
---

<Layout
  title="The Torn Robes Series | Literary Fiction by K.M. Quinn"
  description="Discover the complete Torn Robes trilogy. Faith, transformation, and redemption in K.M. Quinn's literary series."
  canonical="/books/"
>
  <!-- Page header -->
  <section class="py-8 md:py-24">
    <Container class="max-w-3xl mx-auto text-center space-y-6">
      <p class="eyebrow text-[color:var(--color-accent)]">The Complete Series</p>
      <h1 class="display-title text-5xl md:text-6xl leading-tight">
        The Torn Robes Series
      </h1>
      <p class="text-lg text-[color:var(--color-muted)] leading-relaxed">
        Literary fiction that explores faith, transformation, and the choices that define us. Three books. One town. Infinite revelations.
      </p>
    </Container>
  </section>

  <!-- Individual book showcases -->
  {bookDetails.map((book, bookIndex) => {
    const editions = getEditionsByBook(book.title);
    const hardcover = editions.find(e => e.data.format === 'Hardcover' || e.data.format === 'Signed Hardcover');
    const paperback = editions.find(e => e.data.format === 'Paperback' || e.data.format === 'Signed Paperback');
    const isLeftImage = bookIndex % 2 === 0;
    const isLastBook = bookIndex === bookDetails.length - 1;

    return (
      <>
      <section class={`py-16 md:py-24 ${bookIndex % 2 === 1 ? 'bg-gradient-to-b from-transparent via-[rgba(199,142,107,0.04)] to-transparent' : ''}`}>
        <Container>
          <div class={`grid gap-12 lg:grid-cols-[1fr_1fr] lg:items-center ${isLeftImage ? '' : 'lg:auto-cols-fr'}`}>

            <!-- Book image -->
            <div class={`flex justify-center items-start ${isLeftImage ? '' : 'lg:order-2'}`}>
              <div class="max-w-md w-full">
                <img
                  src={book.image}
                  alt={book.title}
                  class="book-cover-full shadow-lg rounded-lg w-full h-auto"
                />
                <p class="eyebrow text-[color:var(--color-accent)] text-center mt-6">{book.number}</p>
              </div>
            </div>

            <!-- Book details -->
            <div class={`space-y-6 ${isLeftImage ? '' : 'lg:order-1'}`}>
              <div>
                <h2 class="display-title text-4xl md:text-5xl leading-tight mb-4">{book.title}</h2>
                <div class="space-y-4 text-[color:var(--color-muted)] leading-relaxed">
                  {book.synopsis.map((paragraph) => (
                    <p class="text-base md:text-lg">{paragraph}</p>
                  ))}
                </div>
              </div>

              <!-- Purchase section -->
              <div class="border-t border-[color:var(--color-line)] pt-8">
                {book.availability === 'coming-soon' ? (
                  <div class="space-y-4">
                    <div class="inline-block px-4 py-2 rounded-full text-sm font-medium bg-[color:var(--color-accent)] text-white">
                      Coming Soon
                    </div>
                    <p class="text-[color:var(--color-muted)]">{book.cta}</p>
                    <a
                      href="/contact-me/"
                      class="inline-block px-6 py-2.5 rounded-full text-sm font-medium button-primary hover:opacity-90 transition-opacity"
                    >
                      Get Preorder Info
                    </a>
                  </div>
                ) : (
                  <div class="space-y-4">
                    <p class="text-sm font-medium text-[color:var(--color-accent)] uppercase tracking-wide">Choose Your Edition</p>
                    <div class="grid gap-4 md:grid-cols-2">
                      {hardcover && (
                        <div class="content-card p-6 flex flex-col">
                          <p class="eyebrow text-[color:var(--color-accent)] mb-2">{hardcover.data.format}</p>
                          <p class="text-2xl font-semibold mb-4 flex-1">${hardcover.data.price}</p>
                          <button class="w-full px-4 py-2.5 rounded-full text-sm font-medium button-primary hover:opacity-90 transition-opacity" disabled>
                            Buy Hardcover
                          </button>
                        </div>
                      )}
                      {paperback && (
                        <div class="content-card p-6 flex flex-col">
                          <p class="eyebrow text-[color:var(--color-accent)] mb-2">{paperback.data.format}</p>
                          <p class="text-2xl font-semibold mb-4 flex-1">${paperback.data.price}</p>
                          <button class="w-full px-4 py-2.5 rounded-full text-sm font-medium button-primary hover:opacity-90 transition-opacity" disabled>
                            Buy Paperback
                          </button>
                        </div>
                      )}
                    </div>
                  </div>
                )}
              </div>
            </div>
          </div>
        </Container>
      </section>

      {/* Customer Reviews Showcase - Below King's Highway */}
      {isLastBook && (
        <section class="py-16 md:py-24 bg-gradient-to-b from-transparent via-[rgba(199,142,107,0.06)] to-transparent">
          <Container>
            <div class="max-w-4xl mx-auto">
              <div class="text-center mb-12">
                <p class="eyebrow text-[color:var(--color-accent)]">What Readers Are Saying</p>
                <h2 class="display-title text-4xl md:text-5xl leading-tight mb-4">Beloved by Readers</h2>
                <p class="text-lg text-[color:var(--color-muted)]">
                  See why readers are captivated by K.M. Quinn's transformative storytelling.
                </p>
              </div>

              {(() => {
                const featuredReviews = allReviews
                  .filter(r => r.data.book === 'Torn Robes: Choices' && r.data.featured)
                  .slice(0, 4);

                return (
                  <div class="grid md:grid-cols-2 gap-6">
                    {featuredReviews.map((review, idx) => (
                      <div
                        class="review-card-featured"
                        style={`animation-delay: ${100 + idx * 100}ms`}
                      >
                        <div class="review-stars-featured">
                          {Array.from({ length: review.data.rating }, (_, i) => (
                            <svg class="star-featured" viewBox="0 0 24 24" fill="currentColor" key={i}>
                              <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" />
                            </svg>
                          ))}
                        </div>
                        <p class="review-text-featured">{review.data.text}</p>
                        <p class="review-author-featured">— {review.data.author}</p>
                      </div>
                    ))}
                  </div>
                );
              })()}
            </div>
          </Container>
        </section>
      )}
      </>
    );
  })}


  <!-- CTA section -->
  <section class="py-16 md:py-24">
    <Container class="max-w-3xl mx-auto text-center space-y-6">
      <h2 class="display-title text-3xl md:text-4xl">Ready to Enter Gilford?</h2>
      <p class="text-lg text-[color:var(--color-muted)]">
        Start with Book One and let K.M. Quinn's characters change how you think about faith, choice, and transformation.
      </p>
      <div class="flex flex-wrap justify-center gap-4">
        <a href="/books/torn-robes-choices/" class="inline-block px-6 py-2.5 rounded-full text-sm font-medium button-primary">
          Start with Choices
        </a>
        <a href="/about-me/" class="inline-block px-6 py-2.5 rounded-full text-sm font-medium button-secondary">
          Meet K.M. Quinn
        </a>
      </div>
    </Container>
  </section>
</Layout>
