---
import Layout from '../../../layouts/Layout.astro';
import Container from '../../../components/site/Container.astro';
import ReviewCard from '../../../components/site/ReviewCard.astro';
import { getProducts, getProductPath } from '../../../lib/content';
import { getCollection } from 'astro:content';

const products = await getProducts();
const editions = products.filter(p => p.data.book === 'Torn Robes: Reckoning');
const allReviews = await getCollection('reviews');
const reviews = allReviews
  .filter(r => r.data.book === 'Torn Robes: Reckoning' && r.data.featured)
  .slice(0, 3);
---

<Layout
  title="Torn Robes: Reckoning | K.M. Quinn"
  description="Book 2 of the Torn Robes series. Available in hardcover, paperback, and signed editions."
  canonical="/books/torn-robes-reckoning/"
>
  <section class="py-8 md:py-24">
    <Container>
      <div class="grid gap-12 lg:grid-cols-[0.9fr_1.1fr]">
        <!-- Left: Book cover -->
        <div class="flex justify-center items-start">
          <img
            src="/images/books/reckoning.jpg"
            alt="Torn Robes: Reckoning"
            class="book-cover-full max-w-xs w-full h-auto shadow-lg rounded-lg"
          />
        </div>

        <!-- Right: Details -->
        <div class="space-y-6">
          <p class="eyebrow text-[color:var(--color-accent)]">Book Two of Three</p>
          <h1 class="display-title text-5xl leading-tight">Torn Robes: Reckoning</h1>

          <div class="space-y-4 text-[color:var(--color-muted)] leading-relaxed">
            <p>
              The journey continues. As the people of Gilford reckon with the consequences of their choices, hidden truths surface and deeper transformations begin. The choices made in the first book now demand accountability.
            </p>
            <p>
              <em>Torn Robes: Reckoning</em> is a story of grace found through facing hard truths. Characters who seemed settled are shaken. Relationships tested are strengthened. New connections form in unexpected ways. Reckoning is not punishment—it's the path to wisdom.
            </p>
            <p>
              In this second volume, K.M. Quinn deepens the spiritual journey of Gilford's inhabitants, showing how faith becomes real when tested by life's most difficult moments.
            </p>
          </div>

          {/* What Readers Say section */}
          {reviews.length > 0 && (
            <div class="my-8 space-y-4">
              <p class="eyebrow text-[color:var(--color-accent)] text-sm">What Readers Say</p>
              {reviews.map((review, idx) => (
                <ReviewCard
                  text={review.data.text}
                  author={review.data.author}
                  rating={review.data.rating}
                  style={`animation-delay: ${100 + idx * 80}ms`}
                />
              ))}
            </div>
          )}

          <hr class="my-8" />

          <!-- Buy on Amazon Section -->
          <div class="mb-12">
            <p class="eyebrow text-[color:var(--color-accent)] mb-4">Buy on Amazon</p>
            <div class="flex flex-wrap gap-4">
              <a
                href="https://www.amazon.com/Torn-Robes-Reckoning-K-Quinn/dp/B0FLD88B37"
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-2 px-6 py-3 rounded-full bg-[color:var(--color-accent)] text-white font-medium hover:bg-[#176f80] transition-colors"
              >
                <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M13.146 8.6c0 .448-.372.8-.83.8-.46 0-.832-.352-.832-.8s.372-.8.83-.8c.459 0 .832.352.832.8zm-5.186 8.4h4.194v-1.2H7.96v1.2zm10.318 3.4H6.186V4h11.092v15.8zm-12.15-17h12.21c.595 0 1.08.486 1.08 1.08V19.8c0 .595-.485 1.08-1.08 1.08H5.128c-.594 0-1.08-.485-1.08-1.08V1.88c0-.594.486-1.08 1.08-1.08z"/>
                </svg>
                Hardcover
              </a>
              <a
                href="https://www.amazon.com/Torn-Robes-Reckoning-K-Quinn/dp/B0C8QZDLB2"
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-2 px-6 py-3 rounded-full bg-[color:var(--color-accent)] text-white font-medium hover:bg-[#176f80] transition-colors"
              >
                <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M4 2h16a2 2 0 0 1 2 2v16a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2zm0 2v14a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V4H4zm3 1h10v2H7V5zm0 4h10v2H7V9zm0 4h10v2H7v-2z"/>
                </svg>
                Paperback
              </a>
            </div>
          </div>

          <!-- Buy a Signed Copy Section -->
          {(() => {
            const signedEditions = editions.filter(e => e.data.format.startsWith('Signed'));
            return signedEditions.length > 0 && (
              <div class="mb-12">
                <p class="eyebrow text-[color:var(--color-accent)] mb-4">Buy a Signed Copy</p>
                <div class="grid gap-4 md:grid-cols-2">
                  {signedEditions.map(edition => (
                    <div class="content-card p-6 flex flex-col">
                      <p class="eyebrow text-[color:var(--color-accent)] mb-2">{edition.data.format}</p>
                      <p class="text-2xl font-semibold mb-4">${edition.data.price}</p>
                      <a
                        href={edition.data.purchaseUrl}
                        class="block text-center px-4 py-2.5 rounded-full text-sm font-medium button-primary hover:opacity-90 transition-opacity"
                      >
                        Buy Now
                      </a>
                    </div>
                  ))}
                </div>
              </div>
            );
          })()}

          <a href="/books/" class="inline-block text-[color:var(--color-accent)]">← Back to All Books</a>
        </div>
      </div>
    </Container>
  </section>
</Layout>
