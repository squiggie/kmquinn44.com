---
import Layout from '../../layouts/Layout.astro';
import Container from '../../components/site/Container.astro';

const kmBooks = [
  {
    title: 'Torn Robes: Choices',
    level: 'Literary fiction / faith and discussion',
    image: '/images/books/torn-robes-choices.png',
    imageAlt: 'Torn Robes: Choices book cover',
    synopsis:
      'The first Torn Robes novel introduces Gilford, Pastor John, and the students and families whose choices shape a town. Useful for discussion around faith, community, courage, and moral decision-making.',
    links: [
      { label: 'Book Details', href: '/books/torn-robes-choices/' },
      { label: 'Hardcover', href: 'https://www.amazon.com/Torn-Robes-Choices-K-Quinn/dp/B0DYCLN3WR' },
      { label: 'Paperback', href: 'https://www.amazon.com/Torn-Robes-K-M-Quinn/dp/B0BGP2233H' },
    ],
  },
  {
    title: 'Torn Robes: Reckoning',
    level: 'Literary fiction / accountability and growth',
    image: '/images/books/reckoning.jpg',
    imageAlt: 'Torn Robes: Reckoning book cover',
    synopsis:
      'The second book deepens the journey through consequence, accountability, and grace. Families can use it to explore character growth, difficult decisions, truth-telling, and spiritual maturity.',
    links: [
      { label: 'Book Details', href: '/books/torn-robes-reckoning/' },
      { label: 'Hardcover', href: 'https://www.amazon.com/Torn-Robes-Reckoning-K-Quinn/dp/B0FLD88B37' },
      { label: 'Paperback', href: 'https://www.amazon.com/Torn-Robes-Reckoning-K-Quinn/dp/B0C8QZDLB2' },
    ],
  },
  {
    title: "Torn Robes: The King's Highway",
    level: 'Literary fiction / trilogy conclusion',
    image: '/images/blog/Torn_Robes_The_Kings__Highway_Cover.avif',
    imageAlt: "Torn Robes: The King's Highway book cover",
    synopsis:
      'The forthcoming final volume brings Gilford to a spiritual and emotional crossroads. Add it to future reading plans for conversations about transformation, redemption, and the long arc of a character journey.',
    links: [{ label: 'Preview Details', href: '/books/torn-robes-kings-highway/' }],
  },
];

const companionGuides = [
  {
    title: 'Companion Guide: Torn Robes: Choices',
    image: '/images/home-school-resources/companion-guide-choices.png',
    imageAlt: 'Companion Guide: Torn Robes: Choices cover',
    synopsis:
      'A companion resource for guided reading, reflection, and discussion alongside Torn Robes: Choices.',
    href: 'https://www.amazon.com/Companion-Guide-Torn-Robes-Choices/dp/B0FFHDQM8K?sr=8-3',
  },
  {
    title: 'Companion Guide: Torn Robes: Reckoning',
    image: '/images/home-school-resources/companion-guide-reckoning.png',
    imageAlt: 'Companion Guide: Torn Robes: Reckoning cover',
    synopsis:
      'A companion resource for guided reading, reflection, and discussion alongside Torn Robes: Reckoning.',
    href: 'https://www.amazon.com/Companion-Guide-Torn-Robes-Reckoning/dp/B0FF24915C?sr=8-4',
  },
];

const additionalAuthors = [
  {
    author: 'Kelly Mitchell Schilling',
    title: "Paulie's Tale Tail",
    audience: 'Children / travel, adventure, and courage',
    image: '/images/books/Paulies-Tale-Ingram-Cover-Proof.png',
    imageAlt: "Paulie's Tale Tail book cover",
    synopsis:
      "Paulie is a patriotic marmot who dreams of adventure and exploring all 50 states. The story can support conversations about curiosity, family expectations, bravery, and discovering one's calling.",
    links: [
      { label: 'Author Site', href: 'https://kellymitchellschilling.com/' },
      { label: 'Book Page', href: 'https://kellymitchellschilling.com/books/' },
      { label: 'Amazon', href: 'https://amazon.com/author/kellymitchellschilling' },
    ],
  },
  {
    author: 'Kelly Mitchell Schilling',
    title: "Paulie's Tale Adventures in Washington DC",
    audience: 'Children / travel, courage, and friendship',
    image: '/images/books/Paulies-Tale-Washington-Paperback-Front.png',
    imageAlt: "Paulie's Tale Adventures in Washington DC book cover",
    synopsis:
      "Paulie's dream trip to Washington DC turns into an unexpected adventure when he gets separated from his family. With help from Sidney, a stray dog who knows the city streets, Paulie learns courage, friendship, and how to keep going when he feels alone.",
    links: [
      { label: 'Author Site', href: 'https://kellymitchellschilling.com/' },
      { label: 'Book Page', href: 'https://kellymitchellschilling.com/books/' },
      { label: 'Amazon', href: 'https://amazon.com/author/kellymitchellschilling' },
    ],
  },
  {
    author: 'S.A. Phillips',
    title: 'The Land Beyond the River',
    audience: 'High school / culture, religion, and philosophy',
    image: '/images/home-school-resources/land-beyond-the-river.jpeg',
    imageAlt: 'The Land Beyond the River book cover',
    synopsis:
      'A post-apocalyptic story about survival, cultural memory, community-building, and storytelling after civilization changes. Useful for older students ready to discuss belief, culture, leadership, and what communities preserve.',
    links: [
      { label: 'Author Site', href: 'https://saphillipswriter.com/' },
      { label: 'Writing Page', href: 'https://saphillipswriter.com/writing/' },
      { label: 'Amazon', href: 'https://www.amazon.com/Land-Beyond-River-S-Phillips-ebook/dp/B0DZZ69WKG' },
    ],
  },
  {
    author: 'S.A. Phillips',
    title: 'The Land Beyond the River Workbook',
    audience: 'High school / discussion and comprehension',
    image: '/images/home-school-resources/land-beyond-the-river-workbook.png',
    imageAlt: 'The Land Beyond the River Workbook cover',
    synopsis:
      'A companion workbook for The Land Beyond the River with structured questions for reading comprehension, discussion, and reflection.',
    links: [
      { label: 'Writing Page', href: 'https://saphillipswriter.com/writing/' },
      { label: 'Amazon', href: 'https://www.amazon.com/Land-Beyond-River-Workbook-Philosophers/dp/B0DVPR539Y?ref_=ast_author_dp' },
    ],
  },
  {
    author: 'S.A. Phillips',
    title: 'Augustine and Jerome',
    audience: 'Church history / philosophy and faith',
    image: '/images/home-school-resources/augustine-jerome.png',
    imageAlt: 'Augustine and Jerome book cover',
    synopsis:
      'A church history resource centered on two major Christian thinkers, suited for learners exploring philosophy, theology, history, and the development of Christian thought.',
    links: [
      { label: 'Writing Page', href: 'https://saphillipswriter.com/writing/' },
      { label: 'Amazon', href: 'https://www.amazon.com/Augustine-Jerome-Church-History-Sophia/dp/B0GPWFMW3Q' },
    ],
  },
  {
    author: 'S.A. Phillips',
    title: 'Augustine and Jerome Workbook',
    audience: 'Church history / guided study',
    image: '/images/home-school-resources/augustine-jerome.png',
    imageAlt: 'Augustine and Jerome cover',
    synopsis:
      'A workbook option for students who benefit from a guided path through Augustine, Jerome, and early church history.',
    links: [
      { label: 'Writing Page', href: 'https://saphillipswriter.com/writing/' },
      { label: 'Amazon', href: 'https://www.amazon.com/Augustine-Jerome-Church-History-Sophia/dp/B0GR5C6BDN?_encoding=UTF8' },
    ],
  },
];

const linkTarget = (href: string) => (href.startsWith('http') ? '_blank' : undefined);
const linkRel = (href: string) => (href.startsWith('http') ? 'noreferrer noopener' : undefined);
const linkClass = (label: string) =>
  label === 'Amazon'
    ? 'inline-flex items-center justify-center gap-2 whitespace-nowrap px-4 py-3 rounded-full bg-[color:var(--color-accent)] text-sm text-white font-medium hover:bg-[#176f80] transition-colors'
    : 'inline-flex items-center justify-center rounded-full px-4 py-3 text-sm font-medium leading-none button-primary';
---

<Layout
  title="Home School Resources | K.M. Quinn"
  description="Homeschool reading resources from K.M. Quinn, companion guides, and additional author recommendations for family discussion and literature study."
  canonical="/home-school-resources/"
>
  <section class="py-8 md:py-24">
    <Container>
      <div class="grid gap-10 lg:grid-cols-[1fr_0.72fr] lg:items-end">
        <div class="max-w-3xl">
          <p class="eyebrow mb-4 text-[color:var(--color-accent)]">Reading & Discussion</p>
          <h1 class="display-title mb-6 text-5xl leading-tight md:text-7xl">
            Home School Resources
          </h1>
          <p class="text-lg leading-relaxed text-[color:var(--color-muted)] md:text-xl">
            Books and companion materials for families who want stories that invite thoughtful conversation, character study, and meaningful reflection.
          </p>
        </div>

        <div class="content-card p-6">
          <p class="mb-3 text-sm font-semibold uppercase tracking-[0.18em] text-[color:var(--color-accent)]">
            Start Here
          </p>
          <p class="text-base leading-relaxed text-[color:var(--color-muted)]">
            These resources are organized for quick planning: K.M. Quinn novels, companion guides, and additional author resources for younger and older students.
          </p>
        </div>
      </div>
    </Container>
  </section>

  <section class="pb-16 md:pb-24">
    <Container class="space-y-16">
      <div>
        <div class="mb-8 max-w-3xl">
          <p class="eyebrow mb-3 text-[color:var(--color-accent)]">K.M. Quinn</p>
          <h2 class="display-title text-4xl leading-tight md:text-5xl">Torn Robes Reading List</h2>
        </div>

        <div class="grid gap-6 lg:grid-cols-3">
          {kmBooks.map((book) => (
            <article class="content-card flex h-full flex-col p-6 md:p-7">
              <div class="mb-5 flex h-64 items-center justify-center rounded-xl border border-[color:var(--color-line)] bg-white p-4">
                <img src={book.image} alt={book.imageAlt} class="max-h-full max-w-full object-contain" loading="lazy" />
              </div>
              <p class="mb-3 text-xs font-semibold uppercase tracking-[0.18em] text-[color:var(--color-accent)]">{book.level}</p>
              <h3 class="display-title mb-4 text-2xl leading-tight">{book.title}</h3>
              <p class="mb-6 flex-1 leading-relaxed text-[color:var(--color-muted)]">{book.synopsis}</p>
              <div class="flex flex-wrap gap-3">
                {book.links.map((link) => (
                  <a
                    href={link.href}
                    target={linkTarget(link.href)}
                    rel={linkRel(link.href)}
                    class={linkClass(link.label)}
                  >
                    {link.label === 'Amazon' && (
                      <svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                        <path d="M13.146 8.6c0 .448-.372.8-.83.8-.46 0-.832-.352-.832-.8s.372-.8.83-.8c.459 0 .832.352.832.8zm-5.186 8.4h4.194v-1.2H7.96v1.2zm10.318 3.4H6.186V4h11.092v15.8zm-12.15-17h12.21c.595 0 1.08.486 1.08 1.08V19.8c0 .595-.485 1.08-1.08 1.08H5.128c-.594 0-1.08-.485-1.08-1.08V1.88c0-.594.486-1.08 1.08-1.08z" />
                      </svg>
                    )}
                    {link.label}
                  </a>
                ))}
              </div>
            </article>
          ))}
        </div>
      </div>

      <div>
        <div class="mb-8 max-w-3xl">
          <p class="eyebrow mb-3 text-[color:var(--color-accent)]">Companion Guides</p>
          <h2 class="display-title text-4xl leading-tight md:text-5xl">Guided Reading Support</h2>
        </div>

        <div class="grid gap-6 md:grid-cols-2">
          {companionGuides.map((guide) => (
            <article class="content-card flex h-full flex-col p-6 md:p-7">
              <div class="mb-5 flex h-72 items-center justify-center rounded-xl border border-[color:var(--color-line)] bg-white p-4">
                <img src={guide.image} alt={guide.imageAlt} class="max-h-full max-w-full object-contain" loading="lazy" />
              </div>
              <h3 class="display-title mb-4 text-2xl leading-tight">{guide.title}</h3>
              <p class="mb-6 flex-1 leading-relaxed text-[color:var(--color-muted)]">{guide.synopsis}</p>
              <a
                href={guide.href}
                target="_blank"
                rel="noreferrer noopener"
                class="inline-flex items-center justify-center gap-2 whitespace-nowrap rounded-full bg-[color:var(--color-accent)] px-4 py-3 text-sm font-medium text-white transition-colors hover:bg-[#176f80]"
              >
                <svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                  <path d="M13.146 8.6c0 .448-.372.8-.83.8-.46 0-.832-.352-.832-.8s.372-.8.83-.8c.459 0 .832.352.832.8zm-5.186 8.4h4.194v-1.2H7.96v1.2zm10.318 3.4H6.186V4h11.092v15.8zm-12.15-17h12.21c.595 0 1.08.486 1.08 1.08V19.8c0 .595-.485 1.08-1.08 1.08H5.128c-.594 0-1.08-.485-1.08-1.08V1.88c0-.594.486-1.08 1.08-1.08z" />
                </svg>
                View on Amazon
              </a>
            </article>
          ))}
        </div>
      </div>

      <div>
        <div class="mb-8 max-w-3xl">
          <p class="eyebrow mb-3 text-[color:var(--color-accent)]">Additional Authors</p>
          <h2 class="display-title text-4xl leading-tight md:text-5xl">More Books for Home Learning</h2>
        </div>

        <div class="grid gap-6 md:grid-cols-2 xl:grid-cols-3">
          {additionalAuthors.map((resource) => (
            <article class="content-card flex h-full flex-col p-6 md:p-7">
              <div class="mb-5 flex h-64 items-center justify-center rounded-xl border border-[color:var(--color-line)] bg-white p-4">
                <img src={resource.image} alt={resource.imageAlt} class="max-h-full max-w-full object-contain" loading="lazy" />
              </div>
              <p class="mb-3 text-xs font-semibold uppercase tracking-[0.18em] text-[color:var(--color-accent)]">{resource.author}</p>
              <h3 class="display-title mb-2 text-2xl leading-tight">{resource.title}</h3>
              <p class="mb-4 text-sm font-semibold text-[color:var(--color-accent)]">{resource.audience}</p>
              <p class="mb-6 flex-1 leading-relaxed text-[color:var(--color-muted)]">{resource.synopsis}</p>
              <div class="flex flex-wrap gap-3">
                {resource.links.map((link) => (
                  <a
                    href={link.href}
                    target="_blank"
                    rel="noreferrer noopener"
                    class={linkClass(link.label)}
                  >
                    {link.label === 'Amazon' && (
                      <svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                        <path d="M13.146 8.6c0 .448-.372.8-.83.8-.46 0-.832-.352-.832-.8s.372-.8.83-.8c.459 0 .832.352.832.8zm-5.186 8.4h4.194v-1.2H7.96v1.2zm10.318 3.4H6.186V4h11.092v15.8zm-12.15-17h12.21c.595 0 1.08.486 1.08 1.08V19.8c0 .595-.485 1.08-1.08 1.08H5.128c-.594 0-1.08-.485-1.08-1.08V1.88c0-.594.486-1.08 1.08-1.08z" />
                      </svg>
                    )}
                    {link.label}
                  </a>
                ))}
              </div>
            </article>
          ))}
        </div>
      </div>
    </Container>
  </section>
</Layout>
