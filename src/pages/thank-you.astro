---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Message Sent">
  <section class="py-20">
    <div class="mx-auto max-w-2xl px-6 text-center md:px-8">
      <p class="eyebrow mb-4 text-[color:var(--color-accent)]">Contact</p>
      <h1 class="display-title mb-4 text-4xl">Message received.</h1>
      <p class="mx-auto mb-8 max-w-xl text-lg text-[color:var(--color-muted)]">
        Thanks for reaching out. Your note is on its way, and someone will respond soon.
      </p>
      <a class="inline-flex rounded-full px-6 py-3 button-primary" href="/">Back to home</a>
    </div>
  </section>
</Layout>
