---
import Layout from '../../layouts/Layout.astro';
import Container from '../../components/site/Container.astro';
---

<Layout title="My Account" description="Account information for direct book purchases." canonical="/my-account/">
  <section class="py-20">
    <Container width="narrow">
      <div class="content-card p-8 text-center md:p-10">
        <p class="eyebrow mb-4 text-[color:var(--color-accent)]">Orders</p>
        <h1 class="display-title mb-4 text-4xl md:text-6xl">Orders are handled through PayPal.</h1>
        <p class="mx-auto max-w-2xl text-lg leading-8 text-[color:var(--color-muted)]">
          This site does not maintain a separate customer account area. If you need help with an
          order, use the contact page and include the name or email used during purchase.
        </p>
        <div class="mt-8 flex flex-wrap justify-center gap-4">
          <a class="inline-flex rounded-full px-6 py-3 button-primary" href="/contact-me/">Contact support</a>
          <a class="inline-flex rounded-full px-6 py-3 button-secondary" href="/shop/">Back to shop</a>
        </div>
      </div>
    </Container>
  </section>
</Layout>
