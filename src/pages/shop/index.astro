---
import Layout from '../../layouts/Layout.astro';
import Container from '../../components/site/Container.astro';
import { getPageBySlug, getProductPath, getProducts } from '../../lib/content';
import site from '../../data/site';

const page = await getPageBySlug('shop');
const products = await getProducts();
const { Content } = page ? await page.render() : { Content: null };
---

<Layout
  title={page?.data.seoTitle ?? page?.data.title ?? 'Shop'}
  description={page?.data.seoDescription || page?.data.description || site.defaultDescription}
  canonical="/shop/"
>
  <section class="py-16 md:py-24">
    <Container class="space-y-10">
      <div class="grid gap-8 lg:grid-cols-[1fr_0.95fr] lg:items-start">
        <div class="space-y-4">
          <p class="eyebrow text-[color:var(--color-accent)]">Shop</p>
          <h1 class="display-title text-5xl md:text-7xl">{page?.data.title ?? 'Shop'}</h1>
          <p class="max-w-2xl text-lg leading-8 text-[color:var(--color-muted)]">
            Choose a signed edition and purchase directly through PayPal-hosted checkout.
          </p>
        </div>
        {Content && (
          <div class="content-card p-8">
            <div class="legacy-content">
              <Content />
            </div>
          </div>
        )}
      </div>

      <div class="grid gap-6 md:grid-cols-2">
        {products.map((product) => (
          <article class="content-card flex h-full flex-col justify-between p-6">
            <div>
              <p class="eyebrow mb-3 text-[color:var(--color-accent)]">{product.data.format}</p>
              <h2 class="display-title text-2xl leading-tight">
                <a href={getProductPath(product)}>{product.data.book}</a>
              </h2>
              <p class="mt-3 text-base text-[color:var(--color-muted)]">{product.data.description}</p>
            </div>
            <div class="mt-6 flex flex-wrap items-center justify-between gap-4">
              <p class="text-lg font-semibold">${product.data.price.toFixed(2)}</p>
              <div class="flex flex-wrap gap-3">
                <a class="inline-flex rounded-full px-5 py-3 button-secondary" href={getProductPath(product)}>
                  Details
                </a>
                <a
                  class="inline-flex rounded-full px-5 py-3 button-primary"
                  href={product.data.purchaseUrl}
                  target="_blank"
                  rel="noreferrer"
                >
                  Buy
                </a>
              </div>
            </div>
          </article>
        ))}
      </div>
    </Container>
  </section>
</Layout>
