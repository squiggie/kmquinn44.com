---
import Container from './Container.astro';
import site from '../../data/site';

const navItems = [
  { href: '/about-me/', label: 'About' },
  { href: '/contact-me/', label: 'Contact' },
];

const resourceItems = [
  { href: '/home-school-resources/', label: 'Home School Resources' },
  { href: '/events/', label: 'Events' },
  { href: '/blog/', label: 'Blog' },
  { href: '/vendor-hub/', label: 'Vendor Hub' },
];
---

<header id="site-header" class="sticky top-0 z-20 border-b border-[color:var(--color-line)] site-surface transition-shadow duration-300">
  <Container class="flex items-center justify-between gap-6 py-4">
    <!-- Logo -->
    <a href="/" class="shrink-0">
      <img src="/images/logo.png" alt={site.title} class="h-10 w-auto" />
    </a>

    <!-- Desktop nav (center) -->
    <nav aria-label="Primary" class="hidden md:flex items-center gap-6 text-sm">
      <a href="/books/" class="nav-link">Books</a>
      <div class="nav-dropdown group relative">
        <button
          type="button"
          class="nav-link inline-flex items-center gap-1"
          aria-haspopup="true"
        >
          Resources
          <svg aria-hidden="true" class="h-3.5 w-3.5 transition-transform duration-200 group-hover:rotate-180 group-focus-within:rotate-180" viewBox="0 0 16 16" fill="none">
            <path d="m4 6 4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
        </button>
        <div class="nav-dropdown-menu absolute left-1/2 top-full hidden min-w-60 -translate-x-1/2 pt-4 group-hover:block group-focus-within:block">
          <div class="rounded-xl border border-[color:var(--color-line)] bg-[rgba(255,255,255,0.96)] p-2 shadow-[0_20px_60px_rgba(31,27,23,0.14)] backdrop-blur">
            {resourceItems.map((item) => (
              <a href={item.href} class="dropdown-link">{item.label}</a>
            ))}
          </div>
        </div>
      </div>
      {navItems.map((item) => (
        <a href={item.href} class="nav-link">{item.label}</a>
      ))}
    </nav>

    <!-- Desktop CTA -->
    <a href="/books/" class="hidden md:inline-flex rounded-full px-5 py-2.5 text-sm button-primary shrink-0">
      Browse Books
    </a>

    <!-- Hamburger toggle (mobile) -->
    <button id="menu-toggle" class="md:hidden flex flex-col gap-1.5 p-2" aria-label="Open menu" aria-expanded="false">
      <span class="hamburger-line"></span>
      <span class="hamburger-line"></span>
      <span class="hamburger-line"></span>
    </button>
  </Container>
</header>

<!-- Mobile fullscreen menu -->
<div id="mobile-menu" class="mobile-menu" role="dialog" aria-label="Navigation">
  <button id="menu-close" aria-label="Close menu" class="absolute top-6 right-6 p-2 text-[color:var(--color-muted)]">✕</button>
  <a href="/books/">Books</a>
  <div class="mobile-menu-group">
    <p>Resources</p>
    {resourceItems.map((item) => (
      <a href={item.href}>{item.label}</a>
    ))}
  </div>
  {navItems.map((item) => (
    <a href={item.href}>{item.label}</a>
  ))}
</div>

<script>
  // Scroll shadow
  const header = document.getElementById('site-header');
  window.addEventListener('scroll', () => {
    header.classList.toggle('header-scrolled', window.scrollY > 10);
  }, { passive: true });

  // Mobile menu toggle
  const toggle = document.getElementById('menu-toggle');
  const close = document.getElementById('menu-close');
  const menu = document.getElementById('mobile-menu');
  toggle.addEventListener('click', () => {
    menu.classList.add('open');
    toggle.setAttribute('aria-expanded', 'true');
  });
  close.addEventListener('click', () => {
    menu.classList.remove('open');
    toggle.setAttribute('aria-expanded', 'false');
  });

  // Close menu when clicking a nav link
  document.querySelectorAll('#mobile-menu a').forEach(link => {
    link.addEventListener('click', () => {
      menu.classList.remove('open');
      toggle.setAttribute('aria-expanded', 'false');
    });
  });
</script>

<style>
  .dropdown-link {
    display: block;
    border-radius: 0.625rem;
    color: var(--color-muted);
    padding: 0.65rem 0.85rem;
    text-decoration: none;
    transition: background 0.2s, color 0.2s;
    white-space: nowrap;
  }

  .dropdown-link:hover,
  .dropdown-link:focus-visible {
    background: rgba(31, 143, 163, 0.1);
    color: var(--color-ink);
    outline: none;
  }

  .mobile-menu-group {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
  }

  .mobile-menu-group p {
    color: var(--color-accent);
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.22em;
    margin: 0;
    text-transform: uppercase;
  }

  .mobile-menu .mobile-menu-group a {
    font-size: clamp(1.5rem, 5vw, 2.4rem);
  }
</style>
