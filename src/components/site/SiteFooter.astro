---
import Container from './Container.astro';
import site from '../../data/site';
---

<footer class="border-t border-[color:var(--color-line)] py-10 text-sm text-[color:var(--color-muted)]">
  <Container class="grid grid-cols-1 gap-8 md:grid-cols-3 md:items-center">

    <!-- Left: tagline + social links -->
    <div class="flex flex-col gap-4">
      <p>Books, essays, events, and community links.</p>
      <div class="flex flex-wrap gap-3">
        <a href={site.socials.facebook} target="_blank" rel="noopener noreferrer" aria-label="Facebook" class="transition-opacity hover:opacity-65">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor"><path d="M22 12a10 10 0 1 0-11.563 9.879v-6.99h-2.54V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.989A10.002 10.002 0 0 0 22 12z"/></svg>
        </a>
        <a href={site.socials.instagram} target="_blank" rel="noopener noreferrer" aria-label="Instagram" class="transition-opacity hover:opacity-65">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 1.17.054 1.97.24 2.428.403a4.92 4.92 0 0 1 1.772 1.153 4.92 4.92 0 0 1 1.153 1.772c.163.458.35 1.257.403 2.428.058 1.265.07 1.645.07 4.849s-.012 3.584-.07 4.85c-.054 1.17-.24 1.97-.403 2.428a4.92 4.92 0 0 1-1.153 1.772 4.92 4.92 0 0 1-1.772 1.153c-.458.163-1.257.35-2.428.403-1.266.058-1.646.07-4.85.07s-3.584-.012-4.849-.07c-1.171-.054-1.97-.24-2.428-.403a4.92 4.92 0 0 1-1.772-1.153 4.92 4.92 0 0 1-1.153-1.772c-.163-.458-.35-1.257-.403-2.428C2.175 15.747 2.163 15.367 2.163 12s.012-3.584.07-4.849c.054-1.171.24-1.97.403-2.428a4.92 4.92 0 0 1 1.153-1.772 4.92 4.92 0 0 1 1.772-1.153c.458-.163 1.257-.35 2.428-.403C8.416 2.175 8.796 2.163 12 2.163zm0-2.163C8.741 0 8.332.014 7.052.072 5.775.13 4.902.333 4.14.63a7.07 7.07 0 0 0-2.561 1.667A7.07 7.07 0 0 0 .63 4.858C.333 5.62.13 6.493.072 7.77.014 9.05 0 9.46 0 12c0 2.541.014 2.951.072 4.23.058 1.277.261 2.15.558 2.912a7.07 7.07 0 0 0 1.667 2.561 7.07 7.07 0 0 0 2.561 1.667c.762.297 1.635.5 2.912.558C9.05 23.986 9.46 24 12 24c2.541 0 2.951-.014 4.23-.072 1.277-.058 2.15-.261 2.912-.558a7.07 7.07 0 0 0 2.561-1.667 7.07 7.07 0 0 0 1.667-2.561c.297-.762.5-1.635.558-2.912C23.986 14.95 24 14.54 24 12c0-2.541-.014-2.951-.072-4.23-.058-1.277-.261-2.15-.558-2.912a7.07 7.07 0 0 0-1.667-2.561A7.07 7.07 0 0 0 19.142.63C18.38.333 17.507.13 16.23.072 14.95.014 14.54 0 12 0zm0 5.838a6.162 6.162 0 1 0 0 12.324 6.162 6.162 0 0 0 0-12.324zm0 10.162a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm6.406-11.845a1.44 1.44 0 1 0 0 2.881 1.44 1.44 0 0 0 0-2.881z"/></svg>
        </a>
        <a href={site.socials.linkedin} target="_blank" rel="noopener noreferrer" aria-label="LinkedIn" class="transition-opacity hover:opacity-65">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
        </a>
        <a href={site.socials.truthSocial} target="_blank" rel="noopener noreferrer" aria-label="Truth Social" class="transition-opacity hover:opacity-65">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.373 0 0 5.373 0 12s5.373 12 12 12 12-5.373 12-12S18.627 0 12 0zm5.25 7.5h-3v9h-2.5v-9h-3V5.5h8.5v2z"/></svg>
        </a>
      </div>
    </div>

    <!-- Middle: logo -->
    <div class="flex justify-center">
      <a href="/"><img src="/images/logo.png" alt={site.title} class="h-24 w-auto" /></a>
    </div>

    <!-- Right: legal links -->
    <div class="flex flex-col gap-2 md:items-end">
      <a href="/legal/#privacy" class="transition-opacity hover:opacity-65">Privacy</a>
      <a href="/legal/#terms" class="transition-opacity hover:opacity-65">Terms</a>
      <a href="/legal/#disclaimer" class="transition-opacity hover:opacity-65">Disclaimer</a>
    </div>

  </Container>
</footer>
