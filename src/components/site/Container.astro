---
interface Props {
  width?: 'narrow' | 'default' | 'wide';
  as?: keyof HTMLElementTagNameMap;
  class?: string;
}

const { width = 'default', as = 'div', class: className = '' } = Astro.props;

const widths = {
  narrow: 'max-w-3xl',
  default: 'max-w-6xl',
  wide: 'max-w-7xl',
};

const Tag = as;
---

<Tag class:list={['mx-auto w-full px-6 md:px-8', widths[width], className]}>
  <slot />
</Tag>
